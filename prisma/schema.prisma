generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeploymentStatus {
  PENDING
  DEPLOYING
  ACTIVE
  FAILED
  ROLLED_BACK
}

enum DeploymentColor {
  BLUE
  GREEN
}

model Project {
  id          String       @id @default(cuid())
  name        String       @unique
  repoUrl     String
  branch      String       @default("main")
  localPath   String
  appPort     Int
  healthPath  String       @default("/health")
  basePort    Int
  buildContext  String       @default(".")
  webhookSecret String?     @unique
  env           Json        @default("{}")
  lockedAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deployments Deployment[]
  jobs        Job[]

  @@index([name])
}

// Run after schema changes: bunx prisma migrate dev --name add_job_queue
model Job {
  id           String    @id @default(uuid())
  type         String // DEPLOY, ROLLBACK, HEALTH_CHECK
  status       String    @default("PENDING") // PENDING, RUNNING, COMPLETE, FAILED, CANCELLED
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deploymentId String?
  payload      Json
  result       Json?
  logs         Json      @default("[]")
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
}

model Deployment {
  id            String           @id @default(cuid())
  version       Int
  imageTag      String
  containerName String
  port          Int
  color         DeploymentColor
  status        DeploymentStatus @default(PENDING)
  errorMessage  String?
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([projectId])
}
